{
  "name": "cuphead-display",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "node-global-key-listener": "*"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cuphead.inputdisplay",
    "productName": "CupheadInputDisplay",
    "asar": true,
    "npmRebuild": true,
    "win": {
      "icon": "assets/cupbr.ico",
      "target": [
        "portable"
      ]
    },
    "files": [
      "main.js",
      "index.html",
      "script.js",
      "binds.js",
      "style.css",
      "assets/**/*"
    ]
  }
}
